{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/razqqm/integrity/main/schema/manifest.schema.json",
    "title": "Deployment Integrity Manifest",
    "description": "Public, append-only commitment of what is currently deployed for a single project.",
    "type": "object",
    "required": ["project", "commit", "builtAt", "publishedAt", "bundles"],
    "additionalProperties": false,
    "properties": {
        "project": {
            "type": "string",
            "description": "Stable project identifier — typically the hostname.",
            "pattern": "^[a-z0-9.-]+$"
        },
        "commit": {
            "type": "string",
            "description": "Short git commit SHA (7+ hex chars).",
            "pattern": "^[0-9a-f]{7,}$"
        },
        "commitFull": {
            "type": ["string", "null"],
            "description": "Full 40-character git commit SHA, when available.",
            "pattern": "^[0-9a-f]{40}$"
        },
        "branch": {
            "type": ["string", "null"],
            "description": "Source branch the build was cut from."
        },
        "builtAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO-8601 timestamp of the build."
        },
        "publishedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO-8601 timestamp this manifest was committed to the integrity repo."
        },
        "bundles": {
            "type": "array",
            "minItems": 1,
            "description": "One entry per artifact whose integrity should be checkable from the running site.",
            "items": {
                "type": "object",
                "required": ["name", "sha256"],
                "additionalProperties": false,
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Logical artifact name (e.g. \"main.js\")."
                    },
                    "url": {
                        "type": ["string", "null"],
                        "format": "uri",
                        "description": "Canonical absolute URL of the deployed artifact, when known at publish time."
                    },
                    "sha256": {
                        "type": "string",
                        "description": "Lowercase hex SHA-256 of the raw artifact bytes.",
                        "pattern": "^[0-9a-f]{64}$"
                    },
                    "size": {
                        "type": ["integer", "null"],
                        "minimum": 0,
                        "description": "Artifact size in bytes."
                    }
                }
            }
        },
        "sourceRepoVisibility": {
            "type": "string",
            "enum": ["public", "private"],
            "description": "Whether the project's source repo is publicly auditable."
        },
        "publicSourceUrl": {
            "type": ["string", "null"],
            "format": "uri",
            "description": "Direct link to the audited commit, when the project source is public."
        }
    }
}
